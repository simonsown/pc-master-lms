# ============================================
# PC Master Builder - Environment Variables
# ============================================
# Copy this file to .env.local and fill in values

# --- Supabase (Required) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Supabase Service Role (Server-side only, keep secret!) ---
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Site URL (Required for OAuth & Vercel) ---
# For production: https://pc-master-lms.vercel.app
# For local: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Admin Email (for admin login) ---
ADMIN_EMAIL=admin@pcmaster.com

# --- n8n Integration Webhooks ---
# Secret used to authenticate n8n -> Next.js webhook calls
N8N_WEBHOOK_SECRET=your-n8n-webhook-secret-here

# n8n self-hosted URL (for n8n -> Next.js callbacks)
N8N_WEBHOOK_URL=http://localhost:5678/webhook
